{
  "name": "@homelab/worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema ../api/prisma/schema.prisma",
    "dev": "pnpm run prisma:generate && pnpm run dev:watch",
    "dev:watch": "tsx watch src/main.ts",
    "build": "pnpm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm run prisma:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.4.1",
    "bullmq": "^5.42.0",
    "ioredis": "^5.5.0",
    "ping": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/testing": "^11.1.14",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "fastify": "^5.7.4",
    "prisma": "6.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
