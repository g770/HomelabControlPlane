{
  "name": "@homelab/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "dev:logged": "node ./scripts/dev-with-logging.mjs",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:mock": "playwright test --project=mock-chromium",
    "test:e2e:smoke": "playwright test --project=real-smoke-chromium",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@homelab/shared": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-query": "^5.66.9",
    "@tanstack/react-query-devtools": "^5.66.9",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "tailwind-merge": "^3.0.2",
    "xterm": "^5.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/testing": "^11.1.14",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.27",
    "fastify": "^5.7.4",
    "postcss": "^8.5.1",
    "jsdom": "^26.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
