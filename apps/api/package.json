{
  "name": "@homelab/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src test prisma --ext .ts",
    "test": "prisma generate && vitest run",
    "test:coverage": "prisma generate && vitest run --coverage",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:drop-email-routes": "tsx prisma/drop-email-notification-routes.ts",
    "prisma:push": "prisma db push",
    "prisma:reconcile-hosts": "tsx prisma/reconcile-host-duplicates.ts",
    "prisma:retire-integrations": "tsx prisma/retire-integrations.ts"
  },
  "dependencies": {
    "@homelab/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "6.4.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.42.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.5.0",
    "node-pty": "^1.0.0",
    "openai": "^5.13.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "ping": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/testing": "^11.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.2.4",
    "fastify": "^5.7.4",
    "prisma": "6.4.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5"
  }
}
