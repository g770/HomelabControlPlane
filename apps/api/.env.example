# This file defines env behavior for the project.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://homelab:replace-with-generated-postgres-password@postgres:5432/homelab
REDIS_URL=redis://redis:6379
JWT_SECRET=replace-with-generated-jwt-secret-min-32-chars
JWT_EXPIRES_IN=8h
APP_MASTER_KEY=replace-with-generated-app-master-key-min-32-chars
OPENAI_MODEL=gpt-5-mini
WEB_ORIGIN=http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120
AI_RETENTION_DAYS=30
RETENTION_DAYS=30
AGENT_INSTALL_ENABLED=false
AGENT_BINARY_STORE_ROOT=/opt/homelab-agent-binaries
AGENT_BINARY_DEFAULT_VERSION=v0.2.0
AGENT_INSTALL_QUEUE_NAME=agent-install-jobs
AGENT_INSTALL_SECRET_TTL_SEC=900
DISCOVERY_ENABLED=true
DISCOVERY_AI_ENABLED=true
DISCOVERY_INTERVAL_SEC=600
DISCOVERY_AI_CATALOG_TTL_SEC=86400
DISCOVERY_MAX_HOSTS_PER_RUN=120
DISCOVERY_MAX_PROBES_PER_HOST=12
DISCOVERY_AUTO_UPSERT=true
DISCOVERY_CONFIDENCE_THRESHOLD=0.75
DISCOVERY_SUBNET_ENABLED=false
DISCOVERY_SUBNET_SCHEDULED=false
DISCOVERY_SUBNET_SCHEDULED_WRITE_APPROVED=false
DISCOVERY_SUBNET_DEFAULT_CIDRS=10.0.0.0/24,172.16.0.0/24,192.168.1.0/24
DISCOVERY_SUBNET_MAX_HOSTS=512
DISCOVERY_SUBNET_CONCURRENCY=24
DISCOVERY_SUBNET_CONNECT_TIMEOUT_MS=750
DISCOVERY_SUBNET_MCP_TOOL_TIMEOUT_MS=120000
